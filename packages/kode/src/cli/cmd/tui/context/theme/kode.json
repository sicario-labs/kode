{
  "$schema": "https://trykode.xyz/theme.json",
  "defs": {
    "darkInk": "#06080f",
    "darkPanel1": "#0b0f1a",
    "darkPanel2": "#111726",
    "darkPanel3": "#19223a",
    "darkLine": "#243352",
    "darkMute": "#3a4868",
    "darkText": "#dbe6ff",
    "darkMuted": "#8492b8",
    "darkCyan": "#5ce4ff",
    "darkCyanDim": "#3aa9c4",
    "darkAmber": "#ffb454",
    "darkAmberDim": "#c98131",
    "darkMagenta": "#d96bff",
    "darkLime": "#9bff7a",
    "darkRed": "#ff5d6c",
    "darkGreen": "#7dffaf",
    "darkYellow": "#ffd166",
    "lightInk": "#f5f7fb",
    "lightPanel1": "#ffffff",
    "lightPanel2": "#f1f4fb",
    "lightPanel3": "#e4eaf5",
    "lightLine": "#cfd6e6",
    "lightMute": "#9aa5be",
    "lightText": "#0b0f1a",
    "lightMuted": "#4a5475",
    "lightCyan": "#0d7da3",
    "lightCyanDim": "#0a5e7a",
    "lightAmber": "#a8650d",
    "lightAmberDim": "#7a4709",
    "lightMagenta": "#8a3aa8",
    "lightLime": "#1a7a30",
    "lightRed": "#c8243a",
    "lightGreen": "#1a7a45",
    "lightYellow": "#a06a00"
  },
  "theme": {
    "primary": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "secondary": {
      "dark": "darkAmber",
      "light": "lightAmber"
    },
    "accent": {
      "dark": "darkMagenta",
      "light": "lightMagenta"
    },
    "error": {
      "dark": "darkRed",
      "light": "lightRed"
    },
    "warning": {
      "dark": "darkAmber",
      "light": "lightAmber"
    },
    "success": {
      "dark": "darkGreen",
      "light": "lightGreen"
    },
    "info": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "text": {
      "dark": "darkText",
      "light": "lightText"
    },
    "textMuted": {
      "dark": "darkMuted",
      "light": "lightMuted"
    },
    "background": {
      "dark": "darkInk",
      "light": "lightInk"
    },
    "backgroundPanel": {
      "dark": "darkPanel1",
      "light": "lightPanel1"
    },
    "backgroundElement": {
      "dark": "darkPanel2",
      "light": "lightPanel2"
    },
    "backgroundMenu": {
      "dark": "darkPanel3",
      "light": "lightPanel3"
    },
    "border": {
      "dark": "darkLine",
      "light": "lightLine"
    },
    "borderActive": {
      "dark": "darkCyanDim",
      "light": "lightCyanDim"
    },
    "borderSubtle": {
      "dark": "darkMute",
      "light": "lightMute"
    },
    "diffAdded": {
      "dark": "darkGreen",
      "light": "lightGreen"
    },
    "diffRemoved": {
      "dark": "darkRed",
      "light": "lightRed"
    },
    "diffContext": {
      "dark": "darkMuted",
      "light": "lightMuted"
    },
    "diffHunkHeader": {
      "dark": "darkCyanDim",
      "light": "lightCyanDim"
    },
    "diffHighlightAdded": {
      "dark": "darkLime",
      "light": "lightLime"
    },
    "diffHighlightRemoved": {
      "dark": "darkRed",
      "light": "lightRed"
    },
    "diffAddedBg": {
      "dark": "#0e2017",
      "light": "#d8f1de"
    },
    "diffRemovedBg": {
      "dark": "#220c11",
      "light": "#f5d4d8"
    },
    "diffContextBg": {
      "dark": "darkPanel1",
      "light": "lightPanel1"
    },
    "diffLineNumber": {
      "dark": "darkMute",
      "light": "lightMute"
    },
    "diffAddedLineNumberBg": {
      "dark": "#0a1812",
      "light": "#c8e1ce"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#190810",
      "light": "#e5c4c8"
    },
    "markdownText": {
      "dark": "darkText",
      "light": "lightText"
    },
    "markdownHeading": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "markdownLink": {
      "dark": "darkAmber",
      "light": "lightAmber"
    },
    "markdownLinkText": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "markdownCode": {
      "dark": "darkLime",
      "light": "lightLime"
    },
    "markdownBlockQuote": {
      "dark": "darkYellow",
      "light": "lightYellow"
    },
    "markdownEmph": {
      "dark": "darkYellow",
      "light": "lightYellow"
    },
    "markdownStrong": {
      "dark": "darkAmber",
      "light": "lightAmber"
    },
    "markdownHorizontalRule": {
      "dark": "darkMute",
      "light": "lightMute"
    },
    "markdownListItem": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "markdownListEnumeration": {
      "dark": "darkAmber",
      "light": "lightAmber"
    },
    "markdownImage": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "markdownImageText": {
      "dark": "darkCyanDim",
      "light": "lightCyanDim"
    },
    "markdownCodeBlock": {
      "dark": "darkText",
      "light": "lightText"
    },
    "syntaxComment": {
      "dark": "darkMute",
      "light": "lightMute"
    },
    "syntaxKeyword": {
      "dark": "darkMagenta",
      "light": "lightMagenta"
    },
    "syntaxFunction": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "syntaxVariable": {
      "dark": "darkAmber",
      "light": "lightAmber"
    },
    "syntaxString": {
      "dark": "darkLime",
      "light": "lightLime"
    },
    "syntaxNumber": {
      "dark": "darkAmber",
      "light": "lightAmber"
    },
    "syntaxType": {
      "dark": "darkCyan",
      "light": "lightCyan"
    },
    "syntaxOperator": {
      "dark": "darkMuted",
      "light": "lightMuted"
    },
    "syntaxPunctuation": {
      "dark": "darkText",
      "light": "lightText"
    }
  }
}
